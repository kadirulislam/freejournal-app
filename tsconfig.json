{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,

    "paths": {
      "@/*": ["./src/*"]
    },

    "ignoreDeprecations": "5.0"
  },

  "include": ["src"]
}
